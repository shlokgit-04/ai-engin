# === AI Engine Environment Variables ===

# Required
BACKEND_BASE_URL=http://localhost:8000/api/v1

# App
APP_NAME=Nurofin Executive AI Engine
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# Provider Configuration
DEFAULT_PROVIDER=openrouter

# OpenRouter (at least one key required)
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_API_KEY_4=
OPENROUTER_API_KEY_5=
OPENROUTER_API_KEY_6=
OPENROUTER_API_KEY_7=
OPENROUTER_API_KEY_8=
OPENROUTER_API_KEY_9=
OPENROUTER_API_KEY_10=
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Gemini (optional - used as fallback provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (optional - used as fallback provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# CORS (comma-separated, default: * for server-side proxy)
CORS_ORIGINS=*

# Backend Auth (for planner tool API calls)
BACKEND_ADMIN_EMAIL=vincent@nurofin.com
BACKEND_ADMIN_PASSWORD=qwerty

# Qdrant (optional)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=nurofin
